# Apify — https://console.apify.com/settings/integrations
APIFY_API_TOKEN=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Magic Hour — https://magichour.ai/developer?tab=api-keys
MAGIC_HOUR_API_KEY=

# MongoDB (Atlas or local), database name path segment is optional; app uses DB name "xwrapped"
# If the DB password contains @ : / ? # & % etc., URL-encode it: npm run encode:mongo-password -- 'your password'
# Example Atlas: mongodb+srv://USER:ENCODED_PASS@cluster.mongodb.net/xwrapped?retryWrites=true&w=majority
# Example local: mongodb://127.0.0.1:27017/xwrapped
# Test: npm run verify:mongo
MONGODB_URI=

# Optional: use pre-cached demo data
DEMO_MODE=

# Production: base URL for share links
PUBLIC_BASE_URL=http://localhost:5173
